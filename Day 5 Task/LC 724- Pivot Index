class Solution {
    public int pivotIndex(int[] nums) {
        int total=0;
        int left=0;
        for(int el:nums)
        total+=el;
        int rsum=total;
        int lsum=0;
        for(int i=0;i<nums.length;i++){
        rsum-=nums[i];
        if(rsum==lsum) return i;
        lsum+=nums[i];
        }
        return -1;
    }
}
